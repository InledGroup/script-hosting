---
import fs from 'node:fs';
import path from 'node:path';

const publicDir = path.join(process.cwd(), 'public');
let files = [];

// Archivos que NO queremos listar como scripts
const ignoredFiles = [
  'favicon.ico',
  'favicon.svg',
  'favicon.png',
  'robots.txt',
  '.DS_Store'
];

try {
  if (fs.existsSync(publicDir)) {
    files = fs.readdirSync(publicDir).filter(file => {
      const fullPath = path.join(publicDir, file);
      const isDirectory = fs.statSync(fullPath).isDirectory();
      return !isDirectory && !ignoredFiles.includes(file) && !file.startsWith('.');
    });
  }
} catch (e) {
  console.error("Error leyendo directorio public:", e);
}

const title = "Inled Scripts";
const favicon = "https://hosted.inled.es/inled-1024x1024.png";
const logo = "https://hosted.inled.es/inled-logo-full.png";
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={favicon} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="light" />
		<title>{title}</title>
	</head>
	<body>
		<div class="container">
			<nav>
				<img src={logo} alt="Inled Logo" class="logo" />
			</nav>

			<main>
				<header>
					<h1>Scripts de Instalación</h1>
					<p>Repositorio oficial de herramientas y automatizaciones.</p>
				</header>

				<section class="content-card">
					{files.length > 0 ? (
						<div class="list-wrapper">
							{files.map((file) => (
								<div class="script-row">
									<div class="file-info">
										<div class="file-icon">
											<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
										</div>
										<span class="file-name">{file}</span>
									</div>
									<div class="actions">
										<button class="btn-copy" data-url={file}>
											Copiar enlace
										</button>
										<a href={`/${file}`} class="btn-download" download>
											Descargar
										</a>
									</div>
								</div>
							))}
						</div>
					) : (
						<div class="empty-state">
							<p>No hay scripts disponibles en este momento.</p>
						</div>
					)}
				</section>
			</main>

			<footer>
				<p>© {new Date().getFullYear()} Inled Cloud Services</p>
			</footer>
		</div>

		<script>
			// Lógica de copia al portapapeles
			const buttons = document.querySelectorAll('.btn-copy');
			buttons.forEach(button => {
				button.addEventListener('click', () => {
					const fileName = button.getAttribute('data-url');
					const url = window.location.origin + '/' + fileName;
					navigator.clipboard.writeText(url);
					
					const originalText = button.textContent;
					button.textContent = '¡Copiado!';
					button.classList.add('copied');
					
					setTimeout(() => {
						button.textContent = originalText;
						button.classList.remove('copied');
					}, 2000);
				});
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f5f5f7;
		--text: #1d1d1f;
		--text-secondary: #86868b;
		--accent: #0071e3;
		--card-bg: rgba(255, 255, 255, 0.85);
		--border: rgba(0, 0, 0, 0.1);
	}

	html, body {
		background-color: var(--bg) !important;
		color: var(--text) !important;
		margin: 0;
		padding: 0;
		height: 100%;
		-webkit-font-smoothing: antialiased;
		color-scheme: light !important;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
		line-height: 1.5;
	}

	.container {
		max-width: 980px;
		margin: 0 auto;
		padding: 0 22px;
	}

	nav {
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 44px;
	}

	.logo {
		height: 32px;
		width: auto;
		opacity: 0.9;
	}

	header {
		text-align: center;
		margin-bottom: 52px;
		padding-top: 20px;
	}

	h1 {
		font-size: 48px;
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-bottom: 8px;
		color: var(--text);
	}

	header p {
		font-size: 21px;
		color: var(--text-secondary);
		font-weight: 400;
	}

	.content-card {
		background: var(--card-bg);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-radius: 18px;
		border: 1px solid var(--border);
		overflow: hidden;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
	}

	.script-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 20px 24px;
		border-bottom: 1px solid var(--border);
		transition: background 0.2s ease;
	}

	.script-row:last-child {
		border-bottom: none;
	}

	.script-row:hover {
		background: rgba(0, 0, 0, 0.02);
	}

	.file-info {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.file-icon {
		color: var(--accent);
		display: flex;
		align-items: center;
	}

	.file-name {
		font-size: 17px;
		font-weight: 500;
		color: var(--text);
	}

	.actions {
		display: flex;
		gap: 12px;
	}

	.btn-copy, .btn-download {
		font-size: 12px;
		font-weight: 500;
		padding: 6px 14px;
		border-radius: 980px;
		cursor: pointer;
		text-decoration: none;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid var(--accent);
		font-family: inherit;
		outline: none;
	}

	.btn-copy {
		background: transparent;
		color: var(--accent);
	}

	.btn-copy:hover {
		background: rgba(0, 113, 227, 0.05);
		transform: scale(1.02);
	}

	.btn-copy.copied {
		background: #34c759;
		border-color: #34c759;
		color: white;
	}

	.btn-download {
		background: var(--accent);
		color: white;
	}

	.btn-download:hover {
		background: #0077ed;
		box-shadow: 0 4px 12px rgba(0, 113, 227, 0.2);
		transform: scale(1.02);
	}

	footer {
		margin-top: 80px;
		padding-bottom: 40px;
		text-align: center;
		font-size: 12px;
		color: var(--text-secondary);
	}

	@media (max-width: 734px) {
		h1 { font-size: 32px; }
		header p { font-size: 17px; }
		.script-row {
			flex-direction: column;
			align-items: flex-start;
			gap: 16px;
		}
		.actions {
			width: 100%;
			justify-content: flex-end;
		}
	}
</style>
